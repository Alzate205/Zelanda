{
  "name": "fincapp",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de gestión integral para Hacienda La Zelanda",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint \"./**/*.{ts,tsx,js,jsx}\" --max-warnings=0",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepare": "husky install",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:pull": "prisma db pull",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "crear-jefe": "node --env-file=.env.local --env-file=.env scripts/crear-primer-jefe.mjs",
    "seed:fase2": "node --env-file=.env --env-file=.env.local scripts/seed-fase2.mjs",
    "verificar:migracion": "node --env-file=.env --env-file=.env.local scripts/verificar-migracion-nucleo.mjs",
    "ci": "npm run lint && npm run test && npm run build",
    "check:types": "tsc --noEmit"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "idb": "^8.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "next": "15.5.18",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-leaflet": "^5.0.0",
    "web-push": "^3.6.7",
    "@sentry/nextjs": "^8.12.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "postcss": "^8.4.49",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "prettier": "^2.8.8",
    "husky": "^8.0.0",
    "lint-staged": "^14.0.0",
    "vitest": "^0.34.6",
    "vite": "^5.0.0",
    "vite-tsconfig-paths": "^4.2.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/user-event": "^14.4.3",
    "jsdom": "^22.1.0",
    "@playwright/test": "^1.40.0",
    "wait-on": "^7.0.1"
  }
}
