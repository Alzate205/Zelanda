# ============================================================
# Variables de entorno · FincApp Hacienda La Zelanda
# Copiar a `.env.local` (Next.js) y `.env` (Prisma) con valores reales.
# Nunca subir secretos al repo.
# ============================================================

# --- Supabase: cliente público (browser y servidor) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase: clave de servicio (SOLO server-side, jamás expuesta al cliente) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Base de datos para Prisma ---
# DATABASE_URL: conexión "pooled" via PgBouncer (puerto 6543), usada por la app.
# DIRECT_URL : conexión directa (puerto 5432), usada por Prisma para migraciones.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- App ---
NEXT_PUBLIC_APP_NAME=La Zelanda

# --- Sentry: observabilidad y error tracking ---
# Obtener DSN ejecutando: npx @sentry/wizard@latest -i nextjs --saas --org zelanda --project javascript-nextjs
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Sentry: credenciales para CI (upload de sourcemaps) ---
# Obtener en https://sentry.io/settings/account/api/auth-tokens/
# Crear token con scope: project:releases, org:read
SENTRY_AUTH_TOKEN=
SENTRY_ORG=zelanda
SENTRY_PROJECT=javascript-nextjs

# --- Push notifications (VAPID) ---
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu@email.com

# --- NDVI · Salud del cultivo (Copernicus Data Space, gratis) ---
# 1. Crear cuenta en https://dataspace.copernicus.eu
# 2. En el dashboard de Sentinel Hub: User settings → OAuth clients → Create
# 3. Copiar el client id y el secret acá (y en Vercel → Environment Variables)
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=
