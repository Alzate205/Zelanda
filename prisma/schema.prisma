/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model usuarios {
  id                    String                  @id @db.Uuid
  email                 String                  @unique
  username              String?                 @unique
  nombre_completo       String
  rol                   rol_usuario
  persona_id            BigInt?
  activo                Boolean                 @default(true)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  asignaciones               asignaciones[]
  cosechas                   cosechas[]
  cosechas_miel              cosechas_miel[]
  despachos                  despachos[]
  movimientos_insumo         movimientos_insumo[]
  salidas_cosecha            salidas_cosecha[]
  push_subscriptions         push_subscriptions[]
  recordatorios              recordatorios[]
  tarifas_tarea              tarifas_tarea[]              @relation("tarifas_tarea_registrado_por")
  tarifas_tarea_borradas      tarifas_tarea[]              @relation("tarifas_tarea_borrado_por")
  pagos                      pagos[]                      @relation("pagos_registrado_por")
  pagos_borrados             pagos[]                      @relation("pagos_borrado_por")
  servicios_contratados      servicios_contratados[]
  jornales                   jornales[]                   @relation("jornales_registrado_por")
  jornales_borrados          jornales[]                   @relation("jornales_borrado_por")
  ausencias                  ausencias[]                  @relation("ausencias_registrado_por")
  ausencias_borradas         ausencias[]                  @relation("ausencias_borrado_por")
  clientes                   clientes[]
  proveedores                proveedores[]
  compras                    compras[]                    @relation("compras_registrado_por")
  compras_borradas           compras[]                    @relation("compras_borrado_por")
  users                      users                        @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  persona                    personas?                    @relation(fields: [persona_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model push_subscriptions {
  id         BigInt   @id @default(autoincrement())
  usuario_id String   @db.Uuid
  endpoint   String   @unique
  p256dh     String
  auth       String
  user_agent String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  usuarios   usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuario_id], map: "idx_push_usuario")
  @@schema("public")
}

