  cubre_desde               DateTime? @db.Date
  cubre_hasta               DateTime? @db.Date
  monto_sugerido            Decimal?  @db.Decimal(12, 2)
  motivo_diferencia         String?
  metodo_pago               String?
  notas                     String?
  registrado_por_usuario_id String    @db.Uuid
  borrado_en                DateTime? @db.Timestamptz(6)
  borrado_por               String?   @db.Uuid
  created_at                DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                DateTime  @default(now()) @db.Timestamptz(6)

  persona       personas               @relation(fields: [persona_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios      usuarios               @relation("pagos_registrado_por", fields: [registrado_por_usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  borrado_por_u usuarios?              @relation("pagos_borrado_por", fields: [borrado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  servicio      servicios_contratados? @relation(fields: [servicio_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([persona_id, fecha(sort: Desc)], map: "idx_pagos_persona_fecha")
  @@index([fecha(sort: Desc)], map: "idx_pagos_fecha")
  @@index([tipo], map: "idx_pagos_tipo")
  @@index([servicio_id], map: "idx_pagos_servicio")
  @@index([borrado_en], map: "idx_pagos_borrado_en")
  @@schema("public")
}

model servicios_contratados {
  id                        BigInt          @id @default(autoincrement())
  persona_id                BigInt
  descripcion               String
  lote_id                   BigInt?
  monto_pactado             Decimal         @db.Decimal(12, 2)
  fecha_inicio              DateTime        @default(dbgenerated("CURRENT_DATE")) @db.Date
  fecha_fin                 DateTime?       @db.Date
  estado                    estado_servicio @default(ACUERDO)
  notas                     String?
  registrado_por_usuario_id String          @db.Uuid
  created_at                DateTime        @default(now()) @db.Timestamptz(6)
  updated_at                DateTime        @default(now()) @db.Timestamptz(6)

  persona  personas @relation(fields: [persona_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lotes    lotes?   @relation(fields: [lote_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  usuarios usuarios @relation(fields: [registrado_por_usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pagos    pagos[]

  @@index([persona_id], map: "idx_servicios_persona")
  @@index([estado], map: "idx_servicios_estado")
  @@index([lote_id], map: "idx_servicios_lote")
  @@schema("public")
}

model jornales {
  id                        BigInt    @id @default(autoincrement())
